datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Setting {
  id        String   @id @db.VarChar(191)
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(191)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Article {
  id              String   @id @default(cuid())
  slug            String   @unique @db.VarChar(191)
  title           String   @db.VarChar(191)
  summary         String   @db.VarChar(500)
  content         String   @db.Text
  images          Json
  // legacy free-text category kept during transition
  category        String?  @db.VarChar(100)
  // new relation to Category table
  categoryId      String?  @db.VarChar(191)
  categoryRef     Category? @relation(fields: [categoryId], references: [id])
  status          String   @default("draft") // 'draft' | 'published'
  publicationDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, publicationDate])
  @@index([categoryId])
}

model Category {
  id        String   @id @default(cuid()) @db.VarChar(191)
  name      String   @unique @db.VarChar(191)
  slug      String   @unique @db.VarChar(191)
  color     String?  @db.VarChar(32)
  order     Int      @default(0)
  articles  Article[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
